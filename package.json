{
  "name": "money-video-claude-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/domain",
    "packages/shared-ts",
    "packages/shared",
    "packages/adapters",
    "packages/usecases",
    "packages/tech-geopolitics-channel"
  ],
  "scripts": {
    "studio": "cd packages/tech-geopolitics-channel && npm run sync && npx remotion studio src/index.ts",
