    "video-editing": "name-only",
    "write-a-skill": "name-only",
    "writing-plans": "name-only",
    "writing-skills": "name-only"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-bash-delete-check.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/git-pre-commit-qa.js\"",
            "if": "Bash(git commit*)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/script-input-sync-check.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-render-preflight.js\"",
            "if": "Bash(*remotion render*)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-voicevox-health.js\"",
            "if": "Bash(*generate-voices*)",
            "timeout": 8
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/auto-sync-script-input.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/ts-typecheck.js\"",
            "timeout": 35
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/yaml-syntax-check.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/prettier-format.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/post-upload-cleanup.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/post-upload-schedule-analytics.js\"",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/audio-duration-validator.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/post-render-report.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/post-script-cta-check.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
