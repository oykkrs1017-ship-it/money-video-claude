{
  "name": "remotion-voicevox-video",
  "version": "1.0.0",
  "description": "Remotion + VOICEVOX動画テンプレート",
  "scripts": {
    "start": "npm run sync && remotion studio src/index.ts",
    "build": "npm run sync && remotion render src/index.ts Main out/video.mp4",
    "voices": "npx ts-node scripts/generate-voices.ts && npm run sync-script",
    "preview": "npm run sync && remotion preview src/index.ts",
    "sync": "npm run sync-settings && npm run sync-script",
    "sync-settings": "npx ts-node scripts/sync-settings.ts",
    "sync-script": "npx ts-node scripts/sync-script.ts",
    "init": "npx ts-node scripts/init-project.ts",
    "editor": "concurrently \"npm run editor:server\" \"npm run editor:client\"",
    "editor:client": "cd editor && npm run dev",
    "editor:server": "cd editor && npm run server",
    "editor:install": "cd editor && npm install",
    "editor:build": "cd editor && npm run build",
    "generate": "npx ts-node scripts/generate-video.ts",
    "create-script": "npx ts-node scripts/create-script.ts",
    "fetch-images": "npx ts-node scripts/fetch-images.ts",
    "validate": "ts-node scripts/validate.ts",
    "yaml-to-json": "npx ts-node scripts/yaml-to-json.ts",
    "pipeline": "npx ts-node --transpile-only scripts/generate.ts",
    "upload": "npx ts-node --transpile-only scripts/upload-youtube.ts",
    "loop": "npx ts-node --transpile-only scripts/autonomous-loop.ts",
    "stats": "npx ts-node --transpile-only scripts/stats.ts",
    "stats:collect": "npx ts-node --transpile-only scripts/stats.ts --collect",
    "collect-analytics": "npx ts-node --transpile-only scripts/collect-analytics.ts",
    "fetch-corpus": "npx ts-node --transpile-only scripts/fetch-competitor-corpus.ts",
    "analyze-patterns": "npx ts-node --transpile-only scripts/analyze-winning-patterns.ts",
    "research-winners": "npm run fetch-corpus && npm run analyze-patterns",
    "new-ep": "npx ts-node --transpile-only scripts/new-episode.ts",
    "new-ep:fresh": "npx ts-node --transpile-only scripts/new-episode.ts --fresh",
    "new-ep:render": "npx ts-node --transpile-only scripts/new-episode.ts --render",
    "optimize-seo": "npx ts-node --transpile-only scripts/optimize-seo.ts",
    "select-topic": "npx ts-node --transpile-only scripts/select-topic.ts",
    "research-topics": "npx ts-node --transpile-only scripts/research-topics.ts",
    "fetch-x": "npx ts-node --transpile-only scripts/fetch-x-post.ts",
    "generate-proposals": "npx ts-node --transpile-only scripts/generate-proposals.ts",
    "research-and-propose": "npx ts-node --transpile-only scripts/research-topics.ts && npx ts-node --transpile-only scripts/generate-proposals.ts",
    "research:reddit": "npx ts-node --transpile-only scripts/research-topics.ts --with-reddit",
    "research:jina": "npx ts-node --transpile-only scripts/research-topics.ts --with-jina",
    "research:full": "npx ts-node --transpile-only scripts/research-topics.ts --with-reddit --with-jina --with-exa",
    "verdict": "python -m pipeline.verdict_engine ../../.. --all",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "slides:generate": "npx ts-node --transpile-only scripts/generate-google-slides.ts",
    "slides:render": "npx remotion render src/index.ts SlidesVideo",
    "pptx:generate": "npx ts-node --transpile-only scripts/generate-pptx.ts",
    "deck:generate": "npx ts-node --transpile-only scripts/generate-deck.ts",
    "html:generate": "npx ts-node --transpile-only scripts/generate-html-slides.ts",
    "html:preview": "npx ts-node --transpile-only scripts/generate-html-slides.ts -- --no-png"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.448",
    "@remotion/cli": "^4.0.448",
    "@remotion/google-fonts": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "budoux": "^0.6.2",
    "dotenv": "^17.4.2",
    "open": "^11.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.448",
    "tsconfig-paths": "^4.2.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@napi-rs/canvas": "^0.1.98",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^2.1.5",
    "concurrently": "^8.2.2",
    "defuddle": "^0.18.1",
    "googleapis": "^171.4.0",
    "js-yaml": "^4.1.1",
    "puppeteer": "^23.11.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
