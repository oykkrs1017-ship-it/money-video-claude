{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@money-video/domain": ["../domain/src/index.ts"],
      "@money-video/domain/*": ["../domain/src/*"],
      "@money-video/shared-ts": ["../shared-ts/src/index.ts"],
      "@money-video/shared-ts/*": ["../shared-ts/src/*"],
      "@money-video/adapters": ["../adapters/src/index.ts"],
      "@money-video/adapters/*": ["../adapters/src/*"],
      "@money-video/usecases": ["../usecases/src/index.ts"],
      "@money-video/usecases/*": ["../usecases/src/*"],
      "@money-video/shared": ["../shared/src/index.ts"],
      "@money-video/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "editor"]
}
