{
  "name": "@money-video/shared-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-cutting concerns for money-video: logger, env, errors, ID generation",
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
